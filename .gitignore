# Environment variables - never commit secrets
.env

# Python cache
__pycache__/
*.py[cod]
*.pyo
*.pyc

# Virtual environments
venv/
penv/
env/
.venv/

# Uploads (user-uploaded files are not tracked in git)
static/uploads/*
!static/uploads/.gitkeep

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS files
.DS_Store
Thumbs.db

# Logs
*.log

# Local database files
*.db
*.sqlite
