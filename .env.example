# Copy this file to .env and fill in your values
# Never commit .env to git

# PostgreSQL connection URL
# Format: postgresql://user:password@host:port/dbname
# Render provides this automatically as DATABASE_URL
DATABASE_URL=postgresql://user:password@localhost:5432/charity_donation

# Flask secret key - use a long random string in production
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-this-to-a-long-random-secret-key

# Admin portal access code
ADMIN_SECRET=HOPE@ADMIN2026

# Set to False in production
DEBUG=False
